    encode gzip zstd
}

# ── Evolucsia Site ───────────────────────────────────
evolucsia.com {
    redir https://www.evolucsia.com{uri} permanent
}
www.evolucsia.com {
    reverse_proxy evolucsia-site:80
    encode gzip zstd
}

