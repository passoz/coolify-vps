# Caddyfile — Gateway principal
# Substitui o Traefik do Coolify.
# Certificados LetsEncrypt automáticos.

{
    admin off
}

# ── Home Assistant ──────────────────────────────────
ha.evolucsia.com {
    reverse_proxy home-assistant:8123
    encode gzip zstd
}

# ── Aluxen ───────────────────────────────────────────
